#!/bin/zsh
set -eu

SCRIPT_DIR="${0:A:h}"
REPO_DIR="${SCRIPT_DIR}/../../.."
PYTHON="$REPO_DIR/.venv/bin/python"
LOG_DIR="$HOME/.codex-lb"
LOG_FILE="$LOG_DIR/menubar.log"

mkdir -p "$LOG_DIR"

if [[ ! -x "$PYTHON" ]]; then
  /usr/bin/osascript -e 'display dialog "codex-lb-cinamon .venv Python을 찾을 수 없습니다. repo 루트에서 의존성을 설치한 뒤 다시 실행하세요." buttons {"OK"} default button "OK" with icon caution'
  exit 1
fi

cd "$REPO_DIR"

nohup "$PYTHON" -m app.cli menubar --manage-server --start-on-launch >> "$LOG_FILE" 2>&1 &
disown
